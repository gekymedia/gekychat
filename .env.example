APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Realtime: reverb (self-hosted, matches mobile) or pusher (Pusher Cloud)
BROADCAST_DRIVER=reverb

REVERB_APP_ID=gekychat
REVERB_APP_KEY=gk-reverb-key-2024
REVERB_APP_SECRET=your-reverb-secret
REVERB_HOST=chat.gekychat.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080
REVERB_SERVER_SCHEME=http

# Vite / Chrome — must match REVERB_* above (run npm run build after changing)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Pusher Cloud fallback (only if BROADCAST_DRIVER=pusher)
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Web Push (PWA) — generate with: php artisan webpush:vapid
VAPID_SUBJECT=mailto:admin@gekychat.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# Firebase Cloud Messaging (mobile push)
FIREBASE_CREDENTIALS=storage/app/firebase/firebase-credentials.json
FIREBASE_PROJECT_ID=

# Apple PushKit VoIP (iOS calls when app is killed — APNs Auth Key .p8 from Apple Developer)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.gekychat.app
APNS_KEY_PATH=storage/app/apns/AuthKey_6J8YUJYUV3.p8
APNS_PRODUCTION=true

# LiveKit (voice/video calls)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# BlackTask Integration
BLACKTASK_URL=https://blacktask.com
BLACKTASK_API_TOKEN=
BLACKTASK_TIMEOUT=30

# Priority Bank Ghana (PBG) Integration - Sika Coins
PBG_API_BASE_URL=https://bank.prioritysolutionsagency.com/api
PBG_API_TOKEN=
PBG_API_TIMEOUT=30

# Priority Bank - Admin Income/Expenditure sync (central-finance API)
PRIORITY_BANK_API_URL=
PRIORITY_BANK_API_TOKEN=
PRIORITY_BANK_SYSTEM_ID=gekychat

# Sika Coins Feature Flags
SIKA_FEATURE_CASHOUT_ENABLED=false
SIKA_FEATURE_MERCHANT_PAY_ENABLED=false

# Sika Internal Webhook Secret
SIKA_INTERNAL_WEBHOOK_SECRET=
